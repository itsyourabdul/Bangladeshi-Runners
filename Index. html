<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bangla Run 🇧🇩 - টেম্পল রানের বাংলা ভার্সন</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&amp;family=Noto+Sans+Bengali:wght@400;700&amp;display=swap');

        :root {
            --bd-green: #006400;
            --bd-red: #FF0000;
            --bd-gold: #FFD700;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(#006400, #228B22);
            font-family: 'Inter', 'Noto Sans Bengali', sans-serif;
            color: white;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            position: relative;
        }

        h1 {
            font-size: 3.2rem;
            font-weight: 700;
            color: #FFD700;
            text-shadow: 
                4px 4px 0 #FF0000,
                -2px -2px 0 #FF0000;
            margin-bottom: 12px;
            letter-spacing: 4px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        canvas {
            border: 12px solid #FFD700;
            border-radius: 20px;
            box-shadow: 
                0 0 40px rgba(255, 215, 0, 0.6),
                0 0 0 8px #FF0000;
            background: #111;
            max-width: 100%;
            max-height: 90vh;
        }

        .ui {
            position: absolute;
            top: 25px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.75);
            padding: 12px 28px;
            border-radius: 50px;
            font-size: 1.6rem;
            font-weight: 700;
            color: #FFD700;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            z-index: 10;
            display: flex;
            align-items: center;
            gap: 12px;
            white-space: nowrap;
        }

        .instructions {
            position: absolute;
            bottom: 20px;
            background: rgba(0, 0, 0, 0.8);
            padding: 14px 24px;
            border-radius: 15px;
            font-size: 1.1rem;
            text-align: center;
            max-width: 820px;
            line-height: 1.4;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.5);
        }

        .flag {
            font-size: 2.2rem;
            animation: wave 2s infinite;
        }

        @keyframes wave {
            0%, 100% { transform: rotate(-8deg); }
            50% { transform: rotate(8deg); }
        }

        .overlay-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            z-index: 20;
            pointer-events: none;
        }
    </style>
</head>
<body>
    <h1>
        <span class="flag">🇧🇩</span>
        BANGLA RUN
        <span class="flag">🇧🇩</span>
    </h1>

    <canvas id="canvas" width="820" height="480"></canvas>

    <div class="ui" id="ui">
        দূরত্ব: <span id="score">0</span>m 
        <span style="margin-left:20px; color:#FFD700;">🥭</span> 
        <span id="mangoCount">0</span>
    </div>

    <div class="instructions" id="instructions">
        ← → বা A D → লেন চেঞ্জ<br>
        ↑ বা W বা SPACE → লাফ (গরু/রিকশা এড়ান)<br>
        ↓ বা S → স্লাইড (ডালপালা এড়ান)<br>
        🥭 ম্যাঙ্গো সংগ্রহ করুন!<br>
        <span style="font-size:0.9rem; opacity:0.8;">মোবাইলে সোয়াইপ করুন • বাংলাদেশের গ্রাম-রাস্তায় অনন্ত দৌড়!</span>
    </div>

    <script>
        /**
         * Bangla Run - Full Temple Run style endless runner
         * Completely self-contained HTML + CSS + JS
         * Bangladeshi vibes: rickshaw, cow, mango, palm trees, lungi, paddy fields, BD flag colors
         * Works on desktop + mobile (keyboard + touch swipe)
         */

        const canvas = document.getElementById('canvas');
        const ctx = canvas.getContext('2d');
        
        const WIDTH = 820;
        const HEIGHT = 480;
        
        let gameState = 'start'; // start, playing, over
        let score = 0;
        let mangoes = 0;
        let highScore = localStorage.getItem('banglaRunHS') ? parseInt(localStorage.getItem('banglaRunHS')) : 0;
        let speed = 6;
        let frame = 0;
        
        let playerLane = 1; // 0 = left, 1 = center, 2 = right
        const laneX = [235, 410, 585];
        
        let playerJump = 0;
        let playerVel = 0;
        let isSliding = false;
        let slideTimer = 0;
        
        let obstacles = [];
        let collectibles = [];
        
        let bgOffset = 0;
        let keys = {};
        
        // Touch variables
        let touchStartX = 0;
        let touchStartY = 0;
        
        // Event listeners
        window.addEventListener('keydown', e => {
            keys[e.key] = true;
            if (gameState === 'start' && (e.key === ' ' || e.key === 'Spacebar')) {
                startGame();
            }
            if (gameState === 'over' && (e.key.toLowerCase() === 'r')) {
                startGame();
            }
        });
        
        window.addEventListener('keyup', e => {
            keys[e.key] = false;
        });
        
        // Mobile touch swipe support
        canvas.addEventListener('touchstart', e => {
            if (gameState !== 'playing') return;
            touchStartX = e.changedTouches[0].screenX;
            touchStartY = e.changedTouches[0].screenY;
        });
        
        canvas.addEventListener('touchend', e => {
            if (gameState !== 'playing') return;
            
            const touchEndX = e.changedTouches[0].screenX;
            const touchEndY = e.changedTouches[0].screenY;
            
            const deltaX = touchEndX - touchStartX;
            const deltaY = touchEndY - touchStartY;
            
            // Horizontal swipe = lane change
            if (Math.abs(deltaX) > 60) {
                if (deltaX > 60 && playerLane < 2) playerLane++;
                else if (deltaX < -60 && playerLane > 0) playerLane--;
            }
            
            // Vertical swipe
            if (Math.abs(deltaY) > 60) {
                if (deltaY < -60 && playerJump === 0) { // swipe up = jump
                    playerVel = -19;
                } else if (deltaY > 60) { // swipe down = slide
                    isSliding = true;
                    slideTimer = 28;
                }
            }
        });
        
        function startGame() {
            gameState = 'playing';
            score = 0;
            mangoes = 0;
            speed = 6;
            frame = 0;
            playerLane = 1;
            playerJump = 0;
            playerVel = 0;
            isSliding = false;
            slideTimer = 0;
            obstacles = [];
            collectibles = [];
            document.getElementById('instructions').style.opacity = '0.3';
        }
        
        function spawnObstacle() {
            const lane = Math.floor(Math.random() * 3);
            const types = ['cow', 'rickshaw', 'branch'];
            const type = types[Math.floor(Math.random() * types.length)];
            
            obstacles.push({
                lane: lane,
                y: -80, // distance from horizon
                type: type
            });
        }
        
        function spawnCollectible() {
            const lane = Math.floor(Math.random() * 3);
            collectibles.push({
                lane: lane,
                y: -80,
                type: 'mango'
            });
        }
        
        function update() {
            if (gameState !== 'playing') return;
            
            frame++;
            score = Math.floor(frame * 0.35 + mangoes * 12);
            
            // Gradually increase difficulty
            if (frame % 65 === 0 && speed < 13) speed += 0.4;
            
            // Controls (keyboard)
            if ((keys['ArrowLeft'] || keys['a'] || keys['A']) && frame % 4 === 0) {
                if (playerLane > 0) playerLane--;
                keys['ArrowLeft'] = keys['a'] = keys['A'] = false;
            }
            if ((keys['ArrowRight'] || keys['d'] || keys['D']) && frame % 4 === 0) {
                if (playerLane < 2) playerLane++;
                keys['ArrowRight'] = keys['d'] = keys['D'] = false;
            }
            if ((keys['ArrowUp'] || keys['w'] || keys['W'] || keys[' ']) && playerJump === 0) {
                playerVel = -19;
                keys['ArrowUp'] = keys['w'] = keys['W'] = keys[' '] = false;
            }
            if (keys['ArrowDown'] || keys['s'] || keys['S']) {
                isSliding = true;
                slideTimer = 28;
                keys['ArrowDown'] = keys['s'] = keys['S'] = false;
            }
            
            // Jump physics
            if (playerJump > 0 || playerVel !== 0) {
                playerJump += playerVel;
                playerVel += 1.05; // gravity
                if (playerJump >= 0) {
                    playerJump = 0;
                    playerVel = 0;
                }
            }
            
            // Slide timer
            if (isSliding) {
                slideTimer--;
                if (slideTimer <= 0) isSliding = false;
            }
            
            // Spawn logic
            if (Math.random() < 0.045 + speed * 0.003) spawnObstacle();
            if (Math.random() < 0.028) spawnCollectible();
            
            // Move everything forward
            for (let i = obstacles.length - 1; i >= 0; i--) {
                obstacles[i].y += speed;
                if (obstacles[i].y > 520) obstacles.splice(i, 1);
            }
            for (let i = collectibles.length - 1; i >= 0; i--) {
                collectibles[i].y += speed;
                if (collectibles[i].y > 520) collectibles.splice(i, 1);
            }
            
            // Collision & collection
            const px = laneX[playerLane];
            const playerBaseY = 310;
            
            // Obstacles
            for (let i = obstacles.length - 1; i >= 0; i--) {
                const o = obstacles[i];
                const screenY = 110 + (o.y * 0.72);
                
                // Collision zone
                if (screenY > 265 && screenY < 375 && o.lane === playerLane) {
                    const isJumpingHigh = playerJump < -25;
                    
                    if (o.type === 'branch') {
                        if (!isSliding) {
                            gameState = 'over';
                            if (score > highScore) {
                                highScore = score;
                                localStorage.setItem('banglaRunHS', Math.floor(highScore));
                            }
                        }
                    } else {
                        // cow or rickshaw
                        if (!isJumpingHigh) {
                            gameState = 'over';
                            if (score > highScore) {
                                highScore = score;
                                localStorage.setItem('banglaRunHS', Math.floor(highScore));
                            }
                        }
                    }
                }
            }
            
            // Collectibles
            for (let i = collectibles.length - 1; i >= 0; i--) {
                const c = collectibles[i];
                const screenY = 110 + (c.y * 0.72);
                
                if (screenY > 265 && screenY < 375 && c.lane === playerLane) {
                    mangoes++;
                    collectibles.splice(i, 1);
                }
            }
            
            // Update UI
            document.getElementById('score').textContent = Math.floor(score);
            document.getElementById('mangoCount').textContent = mangoes;
        }
        
        function drawBackground() {
            // Sky with BD flag colors gradient
            const sky = ctx.createLinearGradient(0, 0, 0, 260);
            sky.addColorStop(0, '#87CEEB');
            sky.addColorStop(1, '#E0F7FA');
            ctx.fillStyle = sky;
            ctx.fillRect(0, 0, WIDTH, 260);
            
            // Sun
            ctx.fillStyle = '#FFCC00';
            ctx.beginPath();
            ctx.arc(680, 75, 38, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = 'rgba(255, 204, 0, 0.3)';
            ctx.beginPath();
            ctx.arc(680, 75, 52, 0, Math.PI * 2);
            ctx.fill();
            
            // Distant paddy fields / hills
            ctx.fillStyle = '#006400';
            ctx.beginPath();
            ctx.moveTo(0, 260);
            ctx.quadraticCurveTo(140, 195, 340, 260);
            ctx.quadraticCurveTo(510, 185, 680, 260);
            ctx.quadraticCurveTo(820, 210, 820, 260);
            ctx.fill();
            
            // Road (earthy Bangladeshi village road)
            ctx.fillStyle = '#C19A6B';
            ctx.fillRect(0, 260, WIDTH, HEIGHT - 260);
            
            // Road borders (green grass)
            ctx.fillStyle = '#008000';
            ctx.fillRect(0, 260, 165, HEIGHT - 260);
            ctx.fillRect(WIDTH - 165, 260, 165, HEIGHT - 260);
            
            // White dashed lane lines (scrolling)
            ctx.strokeStyle = '#FFF';
            ctx.lineWidth = 9;
            ctx.setLineDash([38, 38]);
            const dashOffset = (frame * speed * 1.8) % 76;
            ctx.lineDashOffset = -dashOffset;
            
            ctx.beginPath();
            ctx.moveTo(laneX[0] + 88, 260);
            ctx.lineTo(laneX[0] + 88, HEIGHT);
            ctx.stroke();
            
            ctx.beginPath();
            ctx.moveTo(laneX[1] + 88, 260);
            ctx.lineTo(laneX[1] + 88, HEIGHT);
            ctx.stroke();
            ctx.setLineDash([]);
            
            // Palm trees on both sides (parallax scrolling)
            bgOffset = (bgOffset + speed * 0.65) % 920;
            
            // Left side palms
            ctx.fillStyle = '#8B4513';
            for (let i = 0; i < 5; i++) {
                const x = ((i * 195) + bgOffset) % 1100 - 140;
                // trunk
                ctx.fillRect(x + 18, 205, 14, 90);
                // leaves
                ctx.fillStyle = '#006400';
                ctx.beginPath();
                ctx.ellipse(x + 25, 205, 42, 22, Math.PI * -0.4, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(x + 25, 195, 42, 22, Math.PI * 0.4, 0, Math.PI * 2);
                ctx.fill();
                ctx.fillStyle = '#8B4513';
            }
            
            // Right side palms (different offset for depth)
            for (let i = 0; i < 5; i++) {
                const x = ((i * 195) + bgOffset * 1.3 + 380) % 1100 - 90;
                ctx.fillRect(x + 18, 205, 14, 90);
                ctx.fillStyle = '#006400';
                ctx.beginPath();
                ctx.ellipse(x + 25, 205, 42, 22, Math.PI * -0.4, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(x + 25, 195, 42, 22, Math.PI * 0.4, 0, Math.PI * 2);
                ctx.fill();
                ctx.fillStyle = '#8B4513';
            }
            
            // Some rickshaw art in far background (tiny)
            ctx.fillStyle = 'rgba(255,69,0,0.15)';
            for (let i = 0; i < 3; i++) {
                const rx = ((i * 310) + bgOffset * 0.4) % 1300 - 200;
                ctx.fillRect(rx, 235, 38, 18);
                ctx.fillRect(rx - 8, 225, 54, 12);
            }
        }
        
        function drawPlayer() {
            const x = laneX[playerLane];
            const baseY = 315 - playerJump;
            
            // Torso (orange gamcha style)
            ctx.fillStyle = '#FF4500';
            ctx.fillRect(x - 19, baseY - 62, 38, 44);
            
            // Lungi (green traditional)
            ctx.fillStyle = '#006400';
            if (isSliding) {
                ctx.fillRect(x - 27, baseY - 24, 54, 26);
            } else {
                ctx.fillRect(x - 19, baseY - 24, 38, 32);
            }
            
            // Head
            ctx.fillStyle = '#F4C38A';
            ctx.beginPath();
            ctx.arc(x, baseY - 73, 17, 0, Math.PI * 2);
            ctx.fill();
            
            // Topi / hair
            ctx.fillStyle = '#222';
            ctx.fillRect(x - 18, baseY - 88, 36, 13);
            
            // Eyes
            ctx.fillStyle = '#111';
            ctx.fillRect(x - 9, baseY - 78, 6, 6);
            ctx.fillRect(x + 3, baseY - 78, 6, 6);
            
            // Running arms
            ctx.strokeStyle = '#F4C38A';
            ctx.lineWidth = 9;
            const armSwing = Math.sin(frame / 3) * 9;
            ctx.beginPath();
            ctx.moveTo(x - 19, baseY - 45);
            ctx.lineTo(x - 33, baseY - 28 + armSwing);
            ctx.stroke();
            ctx.beginPath();
            ctx.moveTo(x + 19, baseY - 45);
            ctx.lineTo(x + 33, baseY - 28 - armSwing);
            ctx.stroke();
            
            // Legs
            ctx.strokeStyle = '#006400';
            ctx.lineWidth = 9;
            const legSwing = isSliding ? 0 : Math.sin(frame / 2.2) * 14;
            
            if (isSliding) {
                // Slide pose
                ctx.fillStyle = '#006400';
                ctx.fillRect(x - 30, baseY - 12, 60, 18);
                ctx.fillStyle = '#F4C38A';
                ctx.fillRect(x - 32, baseY + 4, 18, 12);
                ctx.fillRect(x + 14, baseY + 4, 18, 12);
            } else {
                // Normal run
                ctx.beginPath();
                ctx.moveTo(x - 9, baseY - 18);
                ctx.lineTo(x - 18 + legSwing, baseY + 22);
                ctx.stroke();
                
                ctx.beginPath();
                ctx.moveTo(x + 9, baseY - 18);
                ctx.lineTo(x + 18 - legSwing, baseY + 22);
                ctx.stroke();
            }
        }
        
        function drawObstaclesAndCollectibles() {
            // Obstacles
            for (let i = 0; i < obstacles.length; i++) {
                const o = obstacles[i];
                const sy = 110 + o.y * 0.72;
                const size = 26 + (o.y * 0.09);
                const x = laneX[o.lane];
                
                if (sy < 60 || sy > HEIGHT + 20) continue;
                
                if (o.type === 'cow') {
                    // Cow
                    ctx.fillStyle = '#F5F5F5';
                    ctx.fillRect(x - size * 0.9, sy - size * 0.6, size * 1.9, size * 0.95);
                    ctx.fillStyle = '#333';
                    ctx.fillRect(x + size * 0.6, sy - size * 0.65, size * 0.7, size * 0.6); // head
                    // legs
                    ctx.fillRect(x - size * 0.7, sy + size * 0.3, 9, size * 0.6);
                    ctx.fillRect(x - size * 0.2, sy + size * 0.3, 9, size * 0.6);
                    ctx.fillRect(x + size * 0.3, sy + size * 0.3, 9, size * 0.6);
                    ctx.fillRect(x + size * 0.8, sy + size * 0.3, 9, size * 0.6);
                    ctx.fillStyle = '#000';
                    ctx.fillRect(x + size * 0.9, sy - size * 0.4, 10, 10); // ear
                } 
                else if (o.type === 'rickshaw') {
                    // Rickshaw
                    ctx.fillStyle = '#FF4500';
                    ctx.fillRect(x - size * 1.1, sy - size * 0.5, size * 2.1, size * 0.7);
                    ctx.fillStyle = '#FFD700';
                    ctx.fillRect(x - size * 1.3, sy - size * 0.9, size * 2.6, 18); // roof
                    // wheels
                    ctx.fillStyle = '#222';
                    ctx.beginPath();
                    ctx.arc(x - size * 0.6, sy + size * 0.4, size * 0.38, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(x + size * 0.6, sy + size * 0.4, size * 0.38, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.fillStyle = '#ddd';
                    ctx.beginPath();
                    ctx.arc(x - size * 0.6, sy + size * 0.4, size * 0.15, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(x + size * 0.6, sy + size * 0.4, size * 0.15, 0, Math.PI * 2);
                    ctx.fill();
                } 
                else if (o.type === 'branch') {
                    // Low hanging branch
                    ctx.fillStyle = '#8B4513';
                    ctx.fillRect(x - size * 1.4, sy - 14, size * 2.8, 22);
                    ctx.fillStyle = '#228B22';
                    ctx.fillRect(x - size * 1.5, sy - 34, size * 0.9, 24);
                    ctx.fillRect(x + size * 0.6, sy - 34, size * 0.9, 24);
                }
            }
            
            // Mangoes
            for (let i = 0; i < collectibles.length; i++) {
                const c = collectibles[i];
                const sy = 110 + c.y * 0.72;
                const x = laneX[c.lane];
                const size = 22 + (c.y * 0.08);
                
                if (sy < 60 || sy > HEIGHT) continue;
                
                // Mango body
                ctx.fillStyle = '#FFCC00';
                ctx.beginPath();
                ctx.ellipse(x, sy, size * 0.85, size * 1.15, 0.6, 0, Math.PI * 2);
                ctx.fill();
                
                // Highlight
                ctx.fillStyle = '#FFEE99';
                ctx.beginPath();
                ctx.ellipse(x - 6, sy - 4, size * 0.4, size * 0.6, 0.8, 0, Math.PI * 2);
                ctx.fill();
                
                // Leaf
                ctx.fillStyle = '#006400';
                ctx.beginPath();
                ctx.ellipse(x + size * 0.7, sy - size * 0.9, size * 0.65, size * 0.35, -1.2, 0, Math.PI * 2);
                ctx.fill();
                
                // Text emoji
                ctx.font = `${size + 4}px Arial`;
                ctx.fillText('🥭', x - size * 0.6, sy + size * 0.4);
            }
        }
        
        function draw() {
            ctx.clearRect(0, 0, WIDTH, HEIGHT);
            
            drawBackground();
            
            if (gameState === 'playing') {
                drawObstaclesAndCollectibles();
                drawPlayer();
            }
            
            // Start screen
            if (gameState === 'start') {
                ctx.fillStyle = 'rgba(0, 100, 0, 0.85)';
                ctx.fillRect(0, 0, WIDTH, HEIGHT);
                
                ctx.fillStyle = '#FFD700';
                ctx.font = 'bold 68px Inter';
                ctx.textAlign = 'center';
                ctx.fillText('BANGLA RUN', WIDTH / 2, 165);
                
                ctx.fillStyle = '#FF0000';
                ctx.font = '28px Inter';
                ctx.fillText('🇧🇩 গ্রামের রাস্তায় অনন্ত দৌড় 🇧🇩', WIDTH / 2, 215);
                
                ctx.fillStyle = '#fff';
                ctx.font = '24px Inter';
                ctx.fillText('SPACE বা TAP করে শুরু করুন', WIDTH / 2, 285);
                
                ctx.font = '19px Inter';
                ctx.fillText('রিকশা • গরু • ম্যাঙ্গো • পাম গাছ', WIDTH / 2, 325);
                ctx.fillText('বাংলাদেশের ভাইবস দিয়ে তৈরি!', WIDTH / 2, 355);
                
                // Small high score
                ctx.fillStyle = '#FFD700';
                ctx.font = '18px Inter';
                ctx.fillText(`HIGH SCORE: ${highScore}`, WIDTH / 2, 410);
            }
            
            // Game Over screen
            if (gameState === 'over') {
                ctx.fillStyle = 'rgba(178, 0, 0, 0.92)';
                ctx.fillRect(0, 0, WIDTH, HEIGHT);
                
                ctx.fillStyle = '#FFD700';
                ctx.font = 'bold 62px Inter';
                ctx.textAlign = 'center';
                ctx.fillText('GAME OVER', WIDTH / 2, 155);
                
                ctx.fillStyle = '#fff';
                ctx.font = '32px Inter';
                ctx.fillText(`দূরত্ব: ${Math.floor(score)} মিটার`, WIDTH / 2, 225);
                ctx.fillText(`🥭 ম্যাঙ্গো: ${mangoes}`, WIDTH / 2, 265);
                
                if (score >= highScore) {
                    ctx.fillStyle = '#FFD700';
                    ctx.fillText('🎉 নতুন রেকর্ড! 🎉', WIDTH / 2, 310);
                }
                
                ctx.fillStyle = '#fff';
                ctx.font = '26px Inter';
                ctx.fillText(`BEST: ${highScore}`, WIDTH / 2, 355);
                ctx.fillText('R চাপুন আবার খেলতে', WIDTH / 2, 410);
            }
        }
        
        function gameLoop() {
            update();
            draw();
            requestAnimationFrame(gameLoop);
        }
        
        // Boot the game
        gameLoop();
        
